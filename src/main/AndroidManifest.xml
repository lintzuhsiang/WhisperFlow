<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.liveTranslation">

    <!-- ─────────────── PERMISSIONS ─────────────── -->

    <!-- Audio recording from microphone (fallback / testing) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Draw floating overlay window on top of other apps -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Required to run a foreground service at all -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Required for MediaProjection-based audio capture (API 33+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- Keep CPU alive while capturing audio in the background -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Receive boot-complete broadcast to auto-restart service (optional) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LiveTranslation">

        <!-- ─────────────── MAIN ACTIVITY ─────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ─────────────── AUDIO CAPTURE FOREGROUND SERVICE ─────────────── -->
        <!--
            foregroundServiceType="mediaProjection" is mandatory on API 29+.
            Without it, startForeground() will throw an exception at runtime.
        -->
        <service
            android:name=".service.AudioCaptureService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

    </application>

</manifest>
